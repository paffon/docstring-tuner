# Generated artifacts (keep only small committed samples under artifacts/samples/)
/artifacts/*
!/artifacts/samples/

# Datasets & caches (regenerated by `dt-data`)
/data/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Model / HF caches that may leak into the tree
*.safetensors
*.bin

# Editor & tooling
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db
